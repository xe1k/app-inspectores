# Copia este archivo como .env en la VM y completa los valores.
#   cp .env.example .env && nano .env
# NUNCA subas el .env real al repositorio (ya está en .gitignore).

# Dominio público con HTTPS (ej. el de DuckDNS: tuapp.duckdns.org)
DOMINIO=tuapp.duckdns.org

# Clave para firmar las sesiones. Genera una al azar en la VM con:
#   openssl rand -hex 32
SESSION_SECRET=cambia-esto-por-una-clave-larga-al-azar

# Administrador inicial (se crea solo en el primer arranque)
ADMIN_USERNAME=admin@chaba.cl
ADMIN_PASSWORD=cambia-esta-clave
ADMIN_NOMBRE=Administrador
